@model List<Desejo>
@{
    ViewData["Title"] = "Nossa Lista";
    var categorias = (List<Categoria>)ViewBag.Categorias;
    var pendentes = Model.Where(d => !d.Comprado).ToList();
    var comprados = Model.Where(d => d.Comprado).ToList();
    var pendentesPorCat = pendentes.GroupBy(d => d.Categoria?.Nome ?? "Sem categoria").OrderBy(g => g.Key == "Sem categoria" ? 1 : 0).ThenBy(g => g.Key).ToList();
    var compradosPorCat = comprados.GroupBy(d => d.Categoria?.Nome ?? "Sem categoria").OrderBy(g => g.Key == "Sem categoria" ? 1 : 0).ThenBy(g => g.Key).ToList();
    var total = Model.Count;
    var progresso = total > 0 ? (comprados.Count * 100 / total) : 0;
}

<header class="hero">
    <h1>Nossa Lista</h1>
</header>

<main class="container">
    <form class="add-form" method="post" action="/Home/Adicionar">
        <div class="form-row">
            <input type="text" name="nome" placeholder="O que você quer?" required class="input-full">
        </div>

        <div class="form-row">
            <select name="categoriaId" class="input-full">
                <option value="">Sem categoria</option>
                @foreach (var cat in categorias)
                {
                    <option value="@cat.Id">@cat.Nome</option>
                }
            </select>
        </div>

        <div class="links-group">
            <div class="link-row">
                <span class="link-num">1</span>
                <input type="text" name="loja1" placeholder="Loja" class="input-loja">
                <input type="url" name="url1" placeholder="Link do produto" required class="input-url">
            </div>
            <div class="link-row">
                <span class="link-num">2</span>
                <input type="text" name="loja2" placeholder="Loja" class="input-loja">
                <input type="url" name="url2" placeholder="Outra opção (opcional)" class="input-url">
            </div>
            <div class="link-row">
                <span class="link-num">3</span>
                <input type="text" name="loja3" placeholder="Loja" class="input-loja">
                <input type="url" name="url3" placeholder="Mais uma opção (opcional)" class="input-url">
            </div>
        </div>

        <button type="submit" class="btn btn-primary" style="width:100%;margin-top:16px">
            + Adicionar
        </button>
    </form>

    <div class="stats-bar">
        <span class="stat"><span class="stat-dot pending"></span> <strong>@pendentes.Count</strong> pendentes</span>
        <span class="stat"><span class="stat-dot bought"></span> <strong>@comprados.Count</strong> comprados</span>
        @if (total > 0)
        {
            <div class="progress-bar">
                <div class="progress-fill" style="width:@(progresso)%"></div>
            </div>
        }
    </div>

    @if (pendentes.Count == 0 && comprados.Count == 0)
    {
        <div class="empty">
            <div class="empty-icon">✨</div>
            <div class="empty-title">Lista vazia</div>
            <div class="empty-text">Adicione o primeiro presente acima</div>
        </div>
    }
    else
    {
        @if (pendentes.Count > 0)
        {
            <div class="list-section">
                <div class="list-section-title">Pendentes</div>
                @foreach (var grupo in pendentesPorCat)
                {
                    <div class="cat-group">
                        <div class="cat-group-title">@grupo.Key</div>
                        <div class="lista">
                            @foreach (var item in grupo)
                            {
                                <div class="item">
                                    <div class="item-content">
                                        <div class="item-nome">@item.Nome</div>
                                        <div class="item-meta">@item.DataAdicao.ToString("dd/MM/yyyy")</div>
                                        <div class="item-links">
                                            @foreach (var link in item.Links.Select((l, i) => new { Link = l, Index = i }))
                                            {
                                                <div class="link-item">
                                                    <a href="@link.Link.Url" target="_blank" rel="noopener" class="link-btn">
                                                        @(!string.IsNullOrEmpty(link.Link.Loja) ? link.Link.Loja : "Link") ↗
                                                    </a>
                                                    <form method="post" action="/Home/RemoverLink" style="display:inline">
                                                        <input type="hidden" name="id" value="@item.Id">
                                                        <input type="hidden" name="linkIndex" value="@link.Index">
                                                        <button type="submit" class="link-remove" title="Remover link">&times;</button>
                                                    </form>
                                                </div>
                                            }
                                            <form class="add-link-form" method="post" action="/Home/AdicionarLink">
                                                <input type="hidden" name="id" value="@item.Id">
                                                <input type="text" name="loja" placeholder="Loja" class="input-loja-sm">
                                                <input type="url" name="url" placeholder="Link" required class="input-url-sm">
                                                <button type="submit" class="btn-link-add">+</button>
                                            </form>
                                        </div>
                                    </div>
                                    <div class="item-actions">
                                        <form method="post" action="/Home/ToggleComprado" style="display:inline">
                                            <input type="hidden" name="id" value="@item.Id">
                                            <button type="submit" class="btn-icon btn-check" title="Marcar como comprado">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                            </button>
                                        </form>
                                        <form method="post" action="/Home/Remover" style="display:inline" onsubmit="return confirm('Remover este item?')">
                                            <input type="hidden" name="id" value="@item.Id">
                                            <button type="submit" class="btn-icon btn-trash" title="Remover">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }

        @if (comprados.Count > 0)
        {
            <div class="list-section" style="margin-top:24px">
                <div class="list-section-title">Comprados</div>
                @foreach (var grupo in compradosPorCat)
                {
                    <div class="cat-group">
                        <div class="cat-group-title">@grupo.Key</div>
                        <div class="lista">
                            @foreach (var item in grupo)
                            {
                                <div class="item item-comprado">
                                    <div class="item-content">
                                        <div class="item-nome"><s>@item.Nome</s></div>
                                        <div class="item-meta">@item.DataAdicao.ToString("dd/MM/yyyy")</div>
                                    </div>
                                    <div class="item-actions">
                                        <form method="post" action="/Home/ToggleComprado" style="display:inline">
                                            <input type="hidden" name="id" value="@item.Id">
                                            <button type="submit" class="btn-icon" title="Desmarcar">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                                            </button>
                                        </form>
                                        <form method="post" action="/Home/Remover" style="display:inline" onsubmit="return confirm('Remover este item?')">
                                            <input type="hidden" name="id" value="@item.Id">
                                            <button type="submit" class="btn-icon btn-trash" title="Remover">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    }

    <div class="share-hint">
        Compartilhe o link com quem quiser comprar presentes:<br>
        <strong>@Context.Request.Scheme://@Context.Request.Host</strong>
    </div>
</main>
